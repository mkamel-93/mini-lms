{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "clear-build": "rm -rf public/build",
        "build": "npm run clear-build && vite build",
        "dev": "npm run clear-build && vite",
        "prepare": "husky",
        "test:blade": "npx blade-formatter 'resources/views/**/*.blade.php' --check-formatted",
        "fix:blade": "npx blade-formatter 'resources/views/**/*.blade.php' --write"
    },
    "devDependencies": {
        "@alpinejs/collapse": "^3.15.2",
        "@tailwindcss/vite": "^4.1.11",
        "alpinejs": "^3.14.1",
        "autoprefixer": "^10.4.20",
        "axios": "^1.7.4",
        "blade-formatter": "^1.43.0",
        "concurrently": "^9.0.1",
        "husky": "^9.1.7",
        "laravel-vite-plugin": "^2.0",
        "livewire-sortable": "^1.0.0",
        "tailwindcss": "^4.0.7",
        "vite": "^7.0.7",
        "vite-plugin-manifest-sri": "^0.2.0"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
        "lightningcss-linux-x64-gnu": "^1.29.1"
    },
    "dependencies": {
        "plyr": "^3.8.4"
    }
}
